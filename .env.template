# Configuration for SVGMaker MCP Server
# Copy this file to .env and fill in your actual values

# SVGMaker API Key (required)
# Get this from https://svgmaker.io/account
SVGMAKER_API_KEY=your_api_key_here

# Base URL (optional -- default shown below)
# Update if SVGMaker releases a new API version (e.g. /v2)
SVGMAKER_BASE_URL=https://api.svgmaker.io/v1

# Enable debug logging (optional, default: false)
# Set to true for verbose request/response logging during development
SVGMAKER_DEBUG=false
